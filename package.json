  "description": "",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "concurrently": "^9.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^6.4.3"
  }
}
